rules_version = '2';

// Firestore is used as a cache for entitlement decisions, populated by both /verifyPurchase
// (synchronously when the app calls in) and the RTDN Pub/Sub handler (asynchronously when
// Google sends a subscription state change). It is NOT a source of truth — the Play
// Developer API is — and clients must NEVER write to it directly. Reads are also denied
// because the app reads its entitlement via the BillingEntitlementApi HTTPS endpoint, which
// uses the service account credentials internally.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
