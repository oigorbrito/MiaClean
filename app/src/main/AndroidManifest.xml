<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Scoped media permissions (Android 13+). -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />

    <!-- Legacy read permission for API 26..32. On API 33+ it is ignored. -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Foreground service for background scanning via WorkManager. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Explicitly NOT requesting MANAGE_EXTERNAL_STORAGE. -->

    <application
        android:name=".MiaCleanApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MiaClean"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.MiaClean">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
                Static app-shortcut target: long-press on the launcher icon surfaces
                "Escanear agora", which fires this action against MainActivity. The activity
                resolves the action explicitly in onCreate/onNewIntent; no implicit intent
                resolution needed so no intent-filter for this action.
            -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <!--
            Quick Settings tile. Users add it from the QS edit tray. The BIND_QUICK_SETTINGS_TILE
            permission is system-signed; declaring it here only affirms that the service opts in
            to the contract — it doesn't grant the app anything extra.
        -->
        <service
            android:name=".work.ScanTileService"
            android:exported="true"
            android:icon="@android:drawable/stat_sys_download"
            android:label="@string/tile_scan_idle"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!--
            Home-screen widget (Glance-powered). Exposed to the AppWidgetHost via the standard
            APPWIDGET_UPDATE action; taps/refreshes are dispatched by GlanceAppWidgetReceiver.
            No exported="true" override: AppWidgetProvider receivers must be exported for the
            launcher to bind them, and android:exported follows the default-true convention for
            receivers carrying an intent-filter on older platforms. Explicit here for clarity.
        -->
        <receiver
            android:name=".widget.DuplicatesWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_title">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info" />
        </receiver>

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge" />
    </application>

</manifest>
