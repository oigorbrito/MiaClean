    <string name="settings_notify_title">Avisar quando encontrar duplicadas novas</string>
    <string name="settings_notify_desc">Mostra uma notificação quando o scan automático acha duplicadas que ainda não foram limpas. Precisa de permissão de notificação no Android 13+.</string>
