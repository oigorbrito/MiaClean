    <string name="settings_title">Configurações</string>
    <string name="settings_delete_strategy_title">Ao apagar duplicadas</string>
    <string name="settings_delete_strategy_subtitle">Escolha o que acontece com os arquivos removidos. Só afeta Android 11 ou superior — em versões anteriores, a remoção é sempre definitiva.</string>
