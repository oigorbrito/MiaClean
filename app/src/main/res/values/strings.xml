    <string name="settings_background_scan_desc">Every ~24h, while the device is charging or idle, MIA Clean refreshes the duplicates cache. Turn off if you prefer scanning only manually.</string>
    <string name="settings_notify_title">Notify when new duplicates are found</string>
    <string name="settings_notify_desc">Shows a notification when the automatic scan finds duplicates you haven\'t cleaned up yet. Requires notification permission on Android 13+.</string>
