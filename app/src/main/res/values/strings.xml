    <!-- Settings -->
    <string name="settings_title">Settings</string>
    <string name="settings_delete_strategy_title">When deleting duplicates</string>
    <string name="settings_delete_strategy_subtitle">Choose what happens to removed files. Only affects Android 11 or newer — on older versions, deletion is always permanent.</string>
    <string name="settings_strategy_trash">Move to trash (recommended)</string>
    <string name="settings_strategy_trash_desc">Files go to the system trash and can be restored for 30 days. An Undo button appears for a few seconds after deleting.</string>
    <string name="settings_strategy_permanent">Delete permanently</string>
    <string name="settings_strategy_permanent_desc">Files are removed immediately and can\'t be recovered. Frees space right away, no undo.</string>
