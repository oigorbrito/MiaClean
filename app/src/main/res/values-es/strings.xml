    <!-- Settings -->
    <string name="settings_title">Ajustes</string>
    <string name="settings_delete_strategy_title">Al eliminar duplicados</string>
    <string name="settings_delete_strategy_subtitle">Elige qué sucede con los archivos eliminados. Solo afecta a Android 11 o superior — en versiones anteriores, la eliminación siempre es definitiva.</string>
    <string name="settings_strategy_trash">Mover a la papelera (recomendado)</string>
    <string name="settings_strategy_trash_desc">Los archivos van a la papelera del sistema y se pueden restaurar durante 30 días. Verás un botón Deshacer durante unos segundos después de eliminar.</string>
    <string name="settings_strategy_permanent">Eliminar definitivamente</string>
    <string name="settings_strategy_permanent_desc">Los archivos se eliminan de inmediato y no se pueden recuperar. Libera espacio al instante, sin deshacer.</string>
    <string name="settings_debug_section">Depuración</string>
